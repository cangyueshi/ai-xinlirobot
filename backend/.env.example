DATABASE_URL=sqlite:///./ai_psy_counselor.db
SECRET_KEY=your-random-secret-key-here
ADMIN_SECRET_KEY=your-admin-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MINI_PROGRAM_TOKEN_EXPIRE_MINUTES=10080
ADMIN_TOKEN_EXPIRE_MINUTES=480

DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 微信小程序配置（部署前必填）
WECHAT_APPID=your-wechat-appid
WECHAT_APPSECRET=your-wechat-app-secret

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin123456
SUPER_ADMIN_EMAIL=admin@example.com
# 指定微信 openid，该微信号登录小程序时自动成为超级管理员（留空则不启用）
SUPER_ADMIN_WECHAT_OPENID=

# CORS 白名单（多个用逗号分隔，开发用 localhost，生产填你的域名）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 如果未配置 SMTP，密码重置邮件会打印到控制台
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
